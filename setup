tool_install_phase_menu_loop() {
  while true; do
    echo
    echo "Developer tool phases:"
    cat <<EOF
  1. Preview dev-base packages.
  2. Apply dev-base packages.
  3. Preview individual tool installers.
  4. Apply individual tool installers.
  5. Split post-install verification and guidance.
  6. Back to main menu.
EOF
    printf 'Choose [1-6]: '
    local choice
    if ! read -r -e choice; then
      echo
      return 0
    fi
    case "$choice" in
      1)
        echo
        echo "Preparing dev-base package preview..."
        run_machine_install_tools_preview dev-base || { echo "Dev-base preview failed." >&2; continue; }
        echo
        echo "Preview complete."
        ;;
      2)
        run_machine_install_tools_phase_with_confirm dev-base "dev-base packages" || return $?
        ;;
      3)
        echo
        echo "Preparing individual tool installer preview..."
        run_machine_install_tools_preview tools || { echo "Tool installer preview failed." >&2; continue; }
        echo
        echo "Preview complete."
        ;;
      4)
        run_machine_install_tools_apply_with_confirm tools "individual tool installers" || return $?
      ;;
      5)
        while true; do
          echo
          echo "Post-install phases:"
          cat <<EOF
  1. Verify installed tools only.
  2. Run auto post-install actions.
  3. Show manual post-install guidance.
  4. Back to main menu.
EOF
          printf 'Choose [1-4]: '
          local post_choice
          if ! read -r -e post_choice; then
            echo
            return 0
          fi
          case "$post_choice" in
            1) run_machine_install_tools_post_install_verify_only || return $? ;;
            2) run_machine_install_tools_post_install_auto_with_confirm || return $? ;;
            3) run_machine_install_tools_post_install_guidance_only || return $? ;;
            4|"") return 0 ;;
            *) echo "Unknown choice: $post_choice" >&2 ;;
          esac
        done
        ;;
      6|"")
        return 0
        ;;
      *)
        echo "Unknown choice: $choice" >&2
        ;;
    esac
  done
}

ensure_project_envrc_local() {
  local project="${1:-.}"
  local envrc_local="$project/.envrc.local"
  local content=""

  # Build content with GitHub and Codacy tokens
  if command -v gh >/dev/null 2>&1; then
    content+='export GITHUB_TOKEN="$(gh auth token 2>/dev/null)"'$'\n'
  fi

  if [[ -f "$HOME/.codacy/account-token" ]]; then
    content+=$'\n# Codacy account token'$'\n'
    content+='export CODACY_ACCOUNT_TOKEN="$(cat "$HOME/.codacy/account-token")"'$'\n'
  fi

  if [[ -z "$content" ]]; then
    return 0
  fi

  # Write only if not present or needs updating
  if [[ ! -f "$envrc_local" ]]; then
    printf '%s' "$content" > "$envrc_local"
    chmod 600 "$envrc_local"
    if command -v direnv >/dev/null 2>&1; then
      direnv allow "$project" 2>/dev/null || true
    fi
  fi
}

run_machine_apply_with_message() {
  echo
  echo "Applying safe non-protected machine dotfiles and approved install/update recipes..."
  run_machine_apply || return $?
  ensure_mcp_servers
  ensure_project_envrc_local "$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
  return 2
}

run_machine_summary() {
  (cd "$DOTFILES_REPO" && uv run python -m dotfiles_tools.machine_summary \
    --repo "$DOTFILES_REPO" \
    --home "$HOME" \
    --profile machine)
}

extract_machine_recommendation() {
  local summary_text="$1"
  local recommendation_body
  recommendation_body="$(printf '%s\n' "$summary_text" | sed -n 's/^Recommended next step: //p' | head -n1)"
  if [[ -z "$recommendation_body" ]]; then
    recommendation_body="7. Exit without writing - Setup is current and no write action is needed."
  fi
  printf '%s\n' "$recommendation_body"
}

run_machine_details() {
  echo "Full machine doctor:"
  run_machine_doctor
  echo
  echo "Full machine plan:"
  run_machine_plan
}

show_tool_auth_commands() {
  (cd "$DOTFILES_REPO" && uv run python -m dotfiles_tools.baseline)
}

print_summary_section() {
  local summary_text="$1"
  local section_title="$2"
  printf '%s\n' "$summary_text" | awk -v title="$section_title" '
    $0 == title ":" { printing = 1; print; next }
    printing && /^[^ ]/ { exit }
    printing { print }
  '
}

show_safe_changes_preview() {
  local summary_text="$1"
  local preview_kind="$2"
  case "$preview_kind" in
    dotfiles)
      echo "Dotfiles and config files:"
      print_summary_section "$summary_text" "Update existing files with backups"
      print_summary_section "$summary_text" "Create missing files"
      print_summary_section "$summary_text" "Protected/manual files"
      print_summary_section "$summary_text" "Needs attention before apply"
      ;;
    fonts)
      echo "Fonts and terminal setup:"
      print_summary_section "$summary_text" "Fonts"
      ;;
  esac
}

safe_changes_menu_loop() {
  local summary_text="$1"
  while true; do
    echo
    echo "Safe setup changes:"
    cat <<EOF
  1. Preview dotfiles and config files.
  2. Preview fonts and terminal setup.
  3. Apply all safe changes now.
  4. Back to main menu.
EOF
    printf 'Choose [1-4]: '
    local choice
    if ! read -r -e choice; then
      echo
      return 0
    fi
    case "$choice" in
      1) echo; show_safe_changes_preview "$summary_text" dotfiles; echo; echo "Preview complete; returning to main menu."; return 2 ;;
      2) echo; show_safe_changes_preview "$summary_text" fonts; echo; echo "Preview complete; returning to main menu."; return 2 ;;
      3) run_machine_apply_with_message; return $? ;;
      4|"") return 0 ;;
      *) echo "Unknown choice: $choice" >&2 ;;
    esac
  done
}

machine_menu_loop() {
  local recommendation_body="$1"
  local rec_opt="$2"
  local summary_text="$3"
  while true; do
    local opt1="  1. Install / update developer tools (phased submenu, preview, then apply)."
    local opt2="  2. Apply safe non-protected dotfiles."
    local opt3="  3. Show full technical details."
    local opt4="  4. Show tool and sign-in guidance."
    local opt5="  5. Configure / verify API tokens (GitHub, HuggingFace, Codacy)."
    local opt6="  6. Install / update Git hooks for this repo."
    local opt7="  7. Exit without writing."
    [[ "$rec_opt" == "1" ]] && opt1+=" [recommended]"
    [[ "$rec_opt" == "2" ]] && opt2+=" [recommended]"
    [[ "$rec_opt" == "3" ]] && opt3+=" [recommended]"
    [[ "$rec_opt" == "4" ]] && opt4+=" [recommended]"
    [[ "$rec_opt" == "5" ]] && opt5+=" [recommended]"
    [[ "$rec_opt" == "6" ]] && opt6+=" [recommended]"
    [[ "$rec_opt" == "7" ]] && opt7+=" [recommended]"
    cat <<EOF

Recommended next step: ${recommendation_body}
${opt1}
${opt2}
${opt3}
${opt4}
${opt5}
${opt6}
${opt7}
EOF
    printf 'Choose [1-7]: '
    local choice
    if ! read -r -e choice; then
      echo
      echo "No interactive selection received; no changes applied."
      return 0
    fi
    case "$choice" in
      1)
        tool_install_phase_menu_loop
        [[ $? -eq 2 ]] && return 2
        ;;
      2)
        safe_changes_menu_loop "$summary_text"
        [[ $? -eq 2 ]] && return 2
        ;;
      3) echo; run_machine_details ;;
      4) echo; show_tool_auth_commands ;;
      5) echo; configure_machine_api_tokens ;;
      6) echo; cmd_hooks ;;
      7|"") echo "No changes applied."; return 0 ;;
      *) echo "Unknown choice: $choice" >&2 ;;
    esac
  done
}

machine_menu() {
  local recommendation_body="${1:-7. Exit without writing - Setup is current and no write action is needed.}"
  local rec_opt="${2:-7}"
  local summary_text="${3:-}"
  machine_menu_loop "$recommendation_body" "$rec_opt" "$summary_text"
}

cmd_machine_setup() {
  preflight_common
  echo "Preparing/checking this computer with profile: machine"
  echo
  while true; do
    local summary_output recommendation_body rec_opt menu_status
    summary_output="$(run_machine_summary)"
    printf '%s\n' "$summary_output"
    recommendation_body="$(extract_machine_recommendation "$summary_output")"
    rec_opt="${recommendation_body%%.*}"
    [[ "$rec_opt" =~ ^[1-7]$ ]] || rec_opt="7"
    if machine_menu "$recommendation_body" "$rec_opt" "$summary_output"; then
      menu_status=0
    else
      menu_status=$?
    fi
    if [[ "$menu_status" -eq 2 ]]; then
      echo
      continue
    fi
    return "$menu_status"
  done
}

project_is_empty() {
  local project="$1"
  [[ -z "$(find "$project" -mindepth 1 -maxdepth 1 -print -quit)" ]]
}

show_project_vars() {
  local vars="$1"
  echo "Project metadata: $vars"
  sed -n '1,200p' "$vars"
}

CODACY_SECTION_BEGIN="# BEGIN DOTFILES CODACY"
CODACY_SECTION_END="# END DOTFILES CODACY"
HUGGINGFACE_SECTION_BEGIN="# BEGIN DOTFILES HUGGINGFACE"
HUGGINGFACE_SECTION_END="# END DOTFILES HUGGINGFACE"

codacy_safe_name() {
  local raw="$1" out="" char
  local i
  for ((i = 0; i < ${#raw}; i++)); do
    char="${raw:i:1}"
    if [[ "$char" =~ [A-Za-z0-9._-] ]]; then
      out+="$char"
    else
      out+="-"
    fi
  done
  [[ -n "$out" ]] || out="project"
  printf '%s' "$out"
}

escape_env_double_quoted() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//\$/\\$}"
  value="${value//\`/\\\`}"
  printf '%s' "$value"
}

detect_github_identity() {
  local project="$1" url repo_part owner repo
  if ! command -v git >/dev/null 2>&1; then
    return 1
  fi
  url="$(git -C "$project" config --get remote.origin.url 2>/dev/null || true)"
  if [[ -z "$url" ]]; then
    url="$(git -C "$project" remote get-url origin 2>/dev/null || true)"
  fi
  [[ -n "$url" ]] || return 1

  case "$url" in
    git@github.com:*)
      repo_part="${url#git@github.com:}"
      ;;
    https://github.com/*)
      repo_part="${url#https://github.com/}"
      ;;
    http://github.com/*)
      repo_part="${url#http://github.com/}"
      ;;
    *)
      return 1
      ;;
  esac

  owner="${repo_part%%/*}"
  repo="${repo_part#*/}"
  repo="${repo%.git}"
  [[ -n "$owner" && -n "$repo" && "$repo" != "$repo_part" ]] || {
    [[ -n "$owner" && -n "$repo" && "$repo_part" == */* ]] || return 1
  }
  printf '%s\n%s\n' "$owner" "$repo"
}

ship_upload_sarif() {
  local worktree="$1" sarif="$2" commit="$3"
  ( cd "$worktree" && codacy-cli upload \
      -s "$sarif" \
      -c "$commit" \
      -t "$CODACY_PROJECT_TOKEN" \
      -o "${CODACY_USERNAME:-}" \
      -p "${CODACY_ORGANIZATION_PROVIDER:-gh}" \
      -r "${CODACY_PROJECT_NAME:-}" )
}

ship_prepare_codacy_worktree() {
  local worktree="$1" repo_root="$2" codacy_src="" candidate
  if [[ ! -f "$worktree/.codacy/codacy.yaml" ]]; then
    mkdir -p "$worktree/.codacy"
    for candidate in "$repo_root/.codacy/codacy.yaml" "$DOTFILES_REPO/.codacy/codacy.yaml"; do
      if [[ -f "$candidate" ]]; then
        codacy_src="${candidate%/codacy.yaml}"
        break
      fi
    done
    if [[ -n "$codacy_src" ]]; then
      cp "$codacy_src/codacy.yaml" "$worktree/.codacy/codacy.yaml"
      [[ -f "$codacy_src/cli.sh" ]] && cp "$codacy_src/cli.sh" "$worktree/.codacy/cli.sh"
    else
      cat >"$worktree/.codacy/codacy.yaml" <<'YAML'
runtimes:
    - python@3.11.11
tools:
    - pylint@3.3.6
YAML
    fi
  fi
}

prompt_value() {
  local __resultvar="$1" label="$2" default="${3:-}" value
  if [[ -n "$default" ]]; then
    printf '%s [%s]: ' "$label" "$default"
  else
    printf '%s: ' "$label"
  fi
  if ! read -r -e value; then
    echo
    return 1
  fi
  [[ -n "$value" ]] || value="$default"
  printf -v "$__resultvar" '%s' "$value"
}

build_envrc_content() {
  local path="$1" content=""
  if [[ -f "$path" ]]; then
    content="$(cat "$path")"
  fi
  if [[ "$content" == *"source_env_if_exists .envrc.local"* ]]; then
    printf '%s\n' "$content"
    return 0
  fi
  if [[ -n "$content" ]]; then
    printf '%s\n\nsource_env_if_exists .envrc.local\n' "$content"
  else
    printf 'source_env_if_exists .envrc.local\n'
  fi
}

build_codacy_managed_section() {
  local owner="$1" repo="$2"
  shift 2
  local provider owner_escaped repo_escaped
  provider="$(escape_env_double_quoted "gh")"
  owner_escaped="$(escape_env_double_quoted "$owner")"
  repo_escaped="$(escape_env_double_quoted "$repo")"

  printf '%s\n' "$CODACY_SECTION_BEGIN"
  printf 'export CODACY_ORGANIZATION_PROVIDER="%s"\n' "$provider"
  printf 'export CODACY_USERNAME="%s"\n' "$owner_escaped"
  printf 'export CODACY_PROJECT_NAME="%s"\n' "$repo_escaped"

  local account_token_file="$HOME/.codacy/account-token"
  if [[ -f "$account_token_file" ]]; then
    printf 'export CODACY_ACCOUNT_TOKEN="$(cat "%s")"\n' "$account_token_file"
  fi

  while (($# >= 3)); do
    local token_var="$1" token_ref="$2" has_active="$3"
    shift 3
    if [[ "$has_active" -eq 1 ]]; then
      printf 'export %s="$(cat "%s")"\n' "$token_var" "$token_ref"
    else
      printf '# %s not exported because no token file exists yet.\n' "$token_var"
    fi
  done
  printf '%s\n' "$CODACY_SECTION_END"
}

build_envrc_local_content() {
  local path="$1" block="$2" output="" in_managed=0 found=0 line
  if [[ -f "$path" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
      if [[ "$line" == "$CODACY_SECTION_BEGIN" ]]; then
        if [[ "$found" -eq 0 ]]; then
          output+="$block"$'\n'
          found=1
        fi
        in_managed=1
        continue
      fi
      if [[ "$line" == "$CODACY_SECTION_END" ]]; then
        in_managed=0
        continue
      fi
      [[ "$in_managed" -eq 1 ]] && continue
      output+="$line"$'\n'
    done < "$path"
  fi

  if [[ "$found" -eq 0 ]]; then
    [[ -z "${output//[[:space:]]/}" ]] || output+=$'\n'
    output+="$block"$'\n'
  fi
  printf '%s' "$output"
}

replace_managed_section_in_content() {
  local content="$1" begin="$2" end="$3" block="$4"
  local output="" in_managed=0 found=0 line
  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" == "$begin" ]]; then
      if [[ "$found" -eq 0 ]]; then
        output+="$block"$'\n'
        found=1
      fi
      in_managed=1
      continue
    fi
    if [[ "$line" == "$end" ]]; then
      in_managed=0
      continue
    fi
    [[ "$in_managed" -eq 1 ]] && continue
    output+="$line"$'\n'
  done <<<"$content"

  if [[ "$found" -eq 0 ]]; then
    [[ -z "${output//[[:space:]]/}" ]] || output+=$'\n'
    output+="$block"$'\n'
  fi
  printf '%s' "$output"
}

ensure_github_token_in_content() {
  local content="$1"
  local token_line='export GITHUB_TOKEN="$(gh auth token 2>/dev/null)"'
  if grep -qF 'GITHUB_TOKEN' <<<"$content"; then
    printf '%s' "$content"
    return 0
  fi
  if [[ -n "${content//[[:space:]]/}" ]]; then
    printf '%s\n%s\n' "$content" "$token_line"
  else
    printf '%s\n' "$token_line"
  fi
}

ensure_huggingface_token_in_content() {
  local content="$1"
  local block=""
  block+="$HUGGINGFACE_SECTION_BEGIN"$'\n'
  block+='export HF_TOKEN="$(cat "$HOME/.cache/huggingface/token")"'$'\n'
  block+='export HUGGINGFACE_TOKEN="$HF_TOKEN"'$'\n'
  block+="$HUGGINGFACE_SECTION_END"
  replace_managed_section_in_content "$content" "$HUGGINGFACE_SECTION_BEGIN" "$HUGGINGFACE_SECTION_END" "$block"
}

verify_codacy_environment() {
  local project="$1" verification_kind="$2" mode_label="$3"
  local verification_cmd
  case "$verification_kind" in
    project)
      verification_cmd='[[ -n "${CODACY_ORGANIZATION_PROVIDER:-}" && -n "${CODACY_USERNAME:-}" && -n "${CODACY_PROJECT_NAME:-}" && -n "${CODACY_PROJECT_TOKEN:-}" && -n "${CODACY_API_TOKEN:-}" ]]'
      ;;
    account)
      verification_cmd='[[ -n "${CODACY_ORGANIZATION_PROVIDER:-}" && -n "${CODACY_USERNAME:-}" && -n "${CODACY_PROJECT_NAME:-}" && -n "${CODACY_API_TOKEN:-}" ]]'
      ;;
    both)
      verification_cmd='[[ -n "${CODACY_ORGANIZATION_PROVIDER:-}" && -n "${CODACY_USERNAME:-}" && -n "${CODACY_PROJECT_NAME:-}" && -n "${CODACY_PROJECT_TOKEN:-}" && -n "${CODACY_API_TOKEN:-}" ]]'
      ;;
    *)
      echo "✗ Codacy $mode_label environment verification failed: unknown verification mode '$verification_kind'."
      return 1
      ;;
  esac

  if ! command -v direnv >/dev/null 2>&1; then
    echo "✗ Codacy $mode_label environment verification failed: direnv is not installed."
    return 1
  fi

  if (
    unset CODACY_ACCOUNT_TOKEN CODACY_API_TOKEN CODACY_PROJECT_TOKEN
    unset CODACY_ORGANIZATION_PROVIDER CODACY_USERNAME CODACY_PROJECT_NAME
    direnv exec "$project" bash -lc "$verification_cmd"
  ) >/dev/null 2>&1; then
    echo "✓ Codacy $mode_label environment verified for $project"
    return 0
  fi

  echo "✗ Codacy $mode_label environment verification failed for $project"
  echo "  Run: direnv allow \"$project\""
  return 1
}

verify_github_environment() {
  local project="$1"
  if ! command -v gh >/dev/null 2>&1; then
    echo "✗ GitHub authentication verification failed: gh is not installed."
    return 1
  fi

  if [[ -n "$project" && -d "$project" ]] && command -v direnv >/dev/null 2>&1; then
    if direnv exec "$project" bash -lc '[[ -n "${GITHUB_TOKEN:-}" ]] && gh auth status >/dev/null 2>&1' >/dev/null 2>&1; then
      echo "✓ GitHub authentication verified for $project"
      return 0
    fi
    echo "✗ GitHub authentication verification failed for $project"
    echo "  Run: gh auth status -h github.com"
    return 1
  fi

  if gh auth status >/dev/null 2>&1; then
    echo "✓ GitHub authentication verified"
    return 0
  fi

  echo "✗ GitHub authentication verification failed"
  echo "  Run: gh auth login -h github.com"
  return 1
}

verify_huggingface_environment() {
  if ! command -v hf >/dev/null 2>&1; then
    echo "✗ HuggingFace Hub authentication verification failed: hf is not installed."
    return 1
  fi

  if hf auth status >/dev/null 2>&1; then
    echo "✓ HuggingFace Hub authentication verified"
    return 0
  fi

  echo "✗ HuggingFace Hub authentication verification failed"
  echo "  Run: hf auth login"
  return 1
}

backup_existing_file() {
  local path="$1" ts backup counter=0
  ts="$(date +%Y%m%d%H%M%S)"
  backup="${path}.bak.${ts}"
  while [[ -e "$backup" ]]; do
    counter=$((counter + 1))
    backup="${path}.bak.${ts}.${counter}"
  done
  cp -p "$path" "$backup"
}

write_file_if_changed() {
  local path="$1" content="$2" mode="$3" tmp
  tmp="$(mktemp "${TMPDIR:-/tmp}/dotfiles-write.XXXXXX")" || return 1
  printf '%s' "$content" > "$tmp"
  if [[ -f "$path" ]] && cmp -s "$tmp" "$path"; then
    rm -f "$tmp"
    chmod "$mode" "$path"
    return 0
  fi
  if [[ -f "$path" ]]; then
    backup_existing_file "$path"
    chmod u+w "$path" 2>/dev/null || true
  fi
  cp "$tmp" "$path"
  rm -f "$tmp"
  chmod "$mode" "$path"
}

configure_codacy_env() {
  local project="$1" mode_choice mode_label token_var token_name token_prompt
  while true; do
    cat <<EOF

Codacy API access:
  1. Repository token (CODACY_PROJECT_TOKEN).
  2. Account token (CODACY_API_TOKEN).
  3. Back to optional integrations.
EOF
    printf 'Choose [1-3]: '
    if ! read -r -e mode_choice; then
      echo
      echo "Codacy setup cancelled; returning to optional integrations."
      return 0
    fi
    case "$mode_choice" in
      1)
        mode_label="repository token"
        token_var="CODACY_PROJECT_TOKEN"
        token_name="project"
        token_prompt="Paste Codacy repository token"
        break
        ;;
      2)
        mode_label="account token"
        token_var="CODACY_API_TOKEN"
        token_name="account"
        token_prompt="Paste Codacy account token"
        break
        ;;
      3|"")
        echo "Codacy setup cancelled; returning to optional integrations."
        return 0
        ;;
      *) echo "Unknown choice: $mode_choice" >&2 ;;
    esac
  done

  local detected_owner="" detected_repo="" detected identity_lines
  if detected="$(detect_github_identity "$project")"; then
    identity_lines=($detected)
    detected_owner="${identity_lines[0]:-}"
    detected_repo="${identity_lines[1]:-}"
  fi

  local owner repo
  prompt_value owner "GitHub owner" "$detected_owner" || {
    echo "Codacy setup cancelled before repository identity was confirmed."
    return 0
  }
  prompt_value repo "GitHub repository" "$detected_repo" || {
    echo "Codacy setup cancelled before repository identity was confirmed."
    return 0
  }
  if [[ -z "$owner" || -z "$repo" ]]; then
    echo "Owner and repository are required for Codacy environment metadata."
    return 0
  fi

  local token_dir="$HOME/.codacy"
  local project_basename="$(codacy_safe_name "$owner")-$(codacy_safe_name "$repo").project-token"
  local project_token_file="$token_dir/$project_basename"
  local project_token_ref="\$HOME/.codacy/$project_basename"
  local account_token_file="$token_dir/account-token"
  local account_token_ref="\$HOME/.codacy/account-token"

  local token_file token_ref
  if [[ "$token_name" == "account" ]]; then
    token_file="$account_token_file"
    token_ref="$account_token_ref"
  else
    token_file="$project_token_file"
    token_ref="$project_token_ref"
  fi

  printf '%s (leave blank to reuse an existing token file): ' "$token_prompt"
  local token_value=""
  if ! read -r -s token_value; then
    echo
    echo "Codacy setup cancelled before token input completed."
    return 0
  fi
  echo

  local project_has_active=0 account_has_active=0
  [[ -f "$project_token_file" ]] && project_has_active=1
  [[ -f "$account_token_file" ]] && account_has_active=1
  if [[ -n "$token_value" ]]; then
    if [[ "$token_name" == "project" ]]; then
      project_has_active=1
    else
      account_has_active=1
    fi
  fi

  local has_active_token token_action
  if [[ "$token_name" == "project" ]]; then
    has_active_token="$project_has_active"
  else
    has_active_token="$account_has_active"
  fi
  if [[ -n "$token_value" && -f "$token_file" ]]; then
    token_action="update"
  elif [[ -n "$token_value" ]]; then
    token_action="create"
  elif [[ -f "$token_file" ]]; then
    token_action="reuse"
  else
    token_action="not configured"
  fi

  local envrc="$project/.envrc" envrc_local="$project/.envrc.local"
  local block envrc_content envrc_local_content
  block="$(build_codacy_managed_section "$owner" "$repo" \
    "CODACY_PROJECT_TOKEN" "$project_token_ref" "$project_has_active" \
    "CODACY_API_TOKEN" "$account_token_ref" "$account_has_active")"
  envrc_content="$(build_envrc_content "$envrc")"
  envrc_local_content="$(build_envrc_local_content "$envrc_local" "$block")"

  local exported_summary
  if [[ "$project_has_active" -eq 1 && "$account_has_active" -eq 1 ]]; then
    exported_summary="CODACY_PROJECT_TOKEN, CODACY_API_TOKEN"
  elif [[ "$project_has_active" -eq 1 ]]; then
    exported_summary="CODACY_PROJECT_TOKEN"
  elif [[ "$account_has_active" -eq 1 ]]; then
    exported_summary="CODACY_API_TOKEN"
  else
    exported_summary="(none yet)"
  fi

  cat <<EOF

Codacy environment preview:
  - Mode: $mode_label
  - Repository metadata: provider=gh owner=$owner project=$repo
  - Project env file: $envrc
  - Local env bridge: $envrc_local
  - Token storage path: $token_ref ($token_action)
  - Tokens exported: $exported_summary
  - Token values will not be printed or written into project files.
EOF
  if [[ "$has_active_token" -eq 0 ]]; then
    echo "  - A Codacy token is required before activation."
  fi
  printf 'Apply Codacy environment changes? [y/N]: '
  local confirm
  if ! read -r -e confirm || [[ ! "$confirm" =~ ^[Yy]$ ]]; then
    echo "No Codacy environment changes applied."
    return 0
  fi

  if [[ -n "$token_value" ]]; then
    mkdir -p "$token_dir"
    chmod 700 "$token_dir"
    printf '%s\n' "$token_value" > "$token_file"
    chmod 600 "$token_file"
  fi

  write_file_if_changed "$envrc" "$envrc_content" 444
  write_file_if_changed "$envrc_local" "$envrc_local_content" 600

  echo "Codacy $mode_label environment prepared."
  if [[ "$has_active_token" -eq 0 ]]; then
    echo "A Codacy token is required before activation."
  fi

  # Auto-run direnv allow since user already approved the changes
  if command -v direnv >/dev/null 2>&1; then
    if direnv allow "$project" 2>/dev/null; then
      echo "✓ direnv allowed for $project"
      echo "  Environment will load automatically when you cd into the project."
    else
      echo "Note: Run 'direnv allow \"$project\"' manually to activate the environment."
    fi
  else
    echo "Note: direnv not installed. Install via './setup' (machine setup)."
    echo "Once installed, run: direnv allow \"$project\""
  fi

  verify_codacy_environment "$project" "$token_name" "$mode_label" || true
}

cmd_repair_codacy_env() {
  local project="" owner="" repo=""
  while (($#)); do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      --project)
        [[ $# -ge 2 ]] || die "--project requires a value"
        project="$2"; shift 2
        ;;
      --owner)
        [[ $# -ge 2 ]] || die "--owner requires a value"
        owner="$2"; shift 2
        ;;
      --repo)
        [[ $# -ge 2 ]] || die "--repo requires a value"
        repo="$2"; shift 2
        ;;
      -*)
        die "unknown flag for repair-codacy-env: $1"
        ;;
      *)
        [[ -z "$project" ]] || die "repair-codacy-env accepts at most one project path"
        project="$1"; shift
        ;;
    esac
  done
  [[ -n "$project" ]] || project="$PWD"
  [[ -d "$project" ]] || die "project path is not a directory: $project"
  project="$(cd -P "$project" && pwd)"
  if [[ -z "$owner" || -z "$repo" ]]; then
    local detected detected_lines
    if detected="$(detect_github_identity "$project")"; then
      mapfile -t detected_lines <<<"$detected"
      [[ -n "$owner" ]] || owner="${detected_lines[0]:-}"
      [[ -n "$repo"  ]] || repo="${detected_lines[1]:-}"
    fi
  fi
  if [[ -z "$owner" || -z "$repo" ]]; then
    die "could not detect GitHub owner/repo from origin remote in '$project'; pass --owner and --repo"
  fi

  local token_dir="$HOME/.codacy"
  local account_file="$token_dir/account-token"
  local project_basename="$(codacy_safe_name "$owner")-$(codacy_safe_name "$repo").project-token"
  local project_file="$token_dir/$project_basename"
  local has_account=0 has_project=0
  [[ -f "$account_file" ]] && has_account=1
  [[ -f "$project_file" ]] && has_project=1
  if [[ "$has_account" -eq 0 && "$has_project" -eq 0 ]]; then
    die "no Codacy token files found under '$token_dir'; create $account_file or $project_file first"
  fi

  local provider owner_escaped repo_escaped
  provider="$(escape_env_double_quoted "gh")"
  owner_escaped="$(escape_env_double_quoted "$owner")"
  repo_escaped="$(escape_env_double_quoted "$repo")"

  local block=""
  block+="$CODACY_SECTION_BEGIN"$'\n'
  block+="export CODACY_ORGANIZATION_PROVIDER=\"$provider\""$'\n'
  block+="export CODACY_USERNAME=\"$owner_escaped\""$'\n'
  block+="export CODACY_PROJECT_NAME=\"$repo_escaped\""$'\n'
  local exported=()
  if [[ "$has_account" -eq 1 ]]; then
    block+="export CODACY_ACCOUNT_TOKEN=\"\$(cat \"$account_file\")\""$'\n'
    block+="export CODACY_API_TOKEN=\"\$(cat \"$account_file\")\""$'\n'
    exported+=("CODACY_ACCOUNT_TOKEN" "CODACY_API_TOKEN")
  fi
  if [[ "$has_project" -eq 1 ]]; then
    block+="export CODACY_PROJECT_TOKEN=\"\$(cat \"$project_file\")\""$'\n'
    exported+=("CODACY_PROJECT_TOKEN")
  fi
  block+="$CODACY_SECTION_END"

  local envrc_local="$project/.envrc.local"
  local envrc_local_content
  envrc_local_content="$(build_envrc_local_content "$envrc_local" "$block")"
  local api_bridges=()
  if command -v gh >/dev/null 2>&1; then
    envrc_local_content="$(ensure_github_token_in_content "$envrc_local_content")"
    api_bridges+=("GITHUB_TOKEN")
  fi
  if [[ -f "$HOME/.cache/huggingface/token" ]]; then
    chmod 600 "$HOME/.cache/huggingface/token" 2>/dev/null || true
    envrc_local_content="$(ensure_huggingface_token_in_content "$envrc_local_content")"
    api_bridges+=("HF_TOKEN" "HUGGINGFACE_TOKEN")
  fi
  write_file_if_changed "$envrc_local" "$envrc_local_content" 600

  echo "Codacy environment repaired for $owner/$repo"
  echo "  Project: $project"
  echo "  Wrote: $envrc_local"
  echo "  Token files detected:"
  [[ "$has_account" -eq 1 ]] && echo "    - $account_file"
  [[ "$has_project" -eq 1 ]] && echo "    - $project_file"
  local IFS=' '
  echo "  Exports written: ${exported[*]}"
  if [[ ${#api_bridges[@]} -gt 0 ]]; then
    [[ " ${api_bridges[*]} " == *" GITHUB_TOKEN "* ]] && echo "  GitHub token bridge configured"
    [[ " ${api_bridges[*]} " == *" HF_TOKEN "* ]] && echo "  HuggingFace token bridge configured"
  fi

  local verification_kind verification_label
  if [[ "$has_account" -eq 1 && "$has_project" -eq 1 ]]; then
    verification_kind="both"
    verification_label="Codacy repository/account token"
  elif [[ "$has_project" -eq 1 ]]; then
    verification_kind="project"
    verification_label="Codacy repository token"
  else
    verification_kind="account"
    verification_label="Codacy account token"
  fi

  if command -v direnv >/dev/null 2>&1; then
    direnv allow "$project" >/dev/null 2>&1 || true
  fi
  verify_codacy_environment "$project" "$verification_kind" "$verification_label" || true
}

configure_machine_api_tokens() {
  local project="${1:-$PWD}"
  while true; do
    echo
    echo "Tool and sign-in guidance:"
    local gh_status="needs setup" hf_status="needs setup" codacy_status="needs setup"

    # Check status for display
    if command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1; then
      gh_status="verified: $(gh_identity_summary)"
    fi
    if [[ -f "$HOME/.cache/huggingface/token" ]]; then
      hf_status="verified"
    fi
    codacy_status="$(codacy_account_status "$project")"

    cat <<EOF
  1. GitHub (gh) authentication. [$gh_status]
  2. HuggingFace Hub access. [$hf_status]
  3. Codacy API access (account token + project token). [$codacy_status]
  4. Back to main menu.
EOF

    printf "Choose [1-4]: "
    local choice
    if ! read -r -e choice; then
      echo
      return 0
    fi

    case "$choice" in
      1) configure_gh_auth "$project" ;;
      2) configure_huggingface_global "$project" ;;
      3) configure_codacy_env "$project" ;;
      4|"") return 0 ;;
      *) echo "Unknown choice: $choice" >&2 ;;
    esac
  done
}

ensure_github_token_in_envrc_local() {
  local envrc_local="$1"
  local token_line='export GITHUB_TOKEN="$(gh auth token 2>/dev/null)"'
  if grep -qF 'GITHUB_TOKEN' "$envrc_local" 2>/dev/null; then
    return 0
  fi
  printf '%s\n' "$token_line" >> "$envrc_local"
  chmod 600 "$envrc_local"
  echo "  GITHUB_TOKEN added to $envrc_local"
  if command -v direnv >/dev/null 2>&1; then
    direnv allow "$(dirname "$envrc_local")" 2>/dev/null || true
  fi
}

ensure_huggingface_token_in_envrc_local() {
  local envrc_local="$1"
  local token_file="$HOME/.cache/huggingface/token"
  [[ -f "$token_file" ]] || return 0
  chmod 600 "$token_file" 2>/dev/null || true
  local content=""
  [[ -f "$envrc_local" ]] && content="$(cat "$envrc_local")"
  content="$(ensure_huggingface_token_in_content "$content")"
  write_file_if_changed "$envrc_local" "$content" 600
  echo "  HuggingFace token bridge configured in $envrc_local"
  if command -v direnv >/dev/null 2>&1; then
    direnv allow "$(dirname "$envrc_local")" 2>/dev/null || true
  fi
}

configure_gh_auth() {
  local project="${1:-}"
  echo
  echo "Setting up GitHub (gh) authentication..."
  if ! command -v gh >/dev/null 2>&1; then
    echo "gh CLI not found."
    printf "Install gh with apt? [Y/n]: "
    local install_choice
    if read -r -e install_choice && [[ "$install_choice" =~ ^[Yy]?$ ]]; then
      echo "Installing gh via apt..."
      if sudo apt install -y gh; then
        echo "✓ gh installed"
      else
        echo "✗ Failed to install gh. See: https://github.com/cli/cli#installation"
        return 1
      fi
    else
      echo "Skipped gh installation. See: https://github.com/cli/cli#installation"
      return 10
    fi
  fi

  if command -v gh >/dev/null 2>&1; then
    gh auth login
    if gh auth status >/dev/null 2>&1; then
      echo "✓ GitHub authentication configured"
      if [[ -n "$project" ]]; then
        ensure_github_token_in_envrc_local "$project/.envrc.local"
      fi
      verify_github_environment "$project" || true
    fi
  fi
}

configure_huggingface_global() {
  local project="${1:-}"
  echo
  echo "Setting up HuggingFace Hub..."
  if ! command -v hf >/dev/null 2>&1; then
    echo "hf CLI not found. Installing via uv..."
    if uv tool install huggingface-hub; then
      echo "✓ huggingface-hub installed"
      refresh_uv_path
    else
      echo "✗ Failed to install huggingface-hub"
      return 1
    fi
  fi

  if command -v hf >/dev/null 2>&1; then
    hf auth login
    if [[ -f "$HOME/.cache/huggingface/token" ]]; then
      echo "✓ HuggingFace token configured"
      if [[ -n "$project" ]]; then
        ensure_huggingface_token_in_envrc_local "$project/.envrc.local"
      fi
      verify_huggingface_environment || true
    fi
  fi
}

configure_codacy_account_token() {
  local token_value token_dir token_file
  echo
  echo "Setting up Codacy account token..."
  echo "Get your account token from: https://app.codacy.com/account/tokens"
  echo
  printf 'Paste Codacy account token (or press enter to skip): '
  if ! read -r -s token_value; then
    echo
    echo "Codacy account token setup cancelled."
    return 0
  fi
  echo

  if [[ -z "$token_value" ]]; then
    echo "No token provided. Codacy account token will not be configured."
    return 0
  fi

  token_dir="$HOME/.codacy"
  token_file="$token_dir/account-token"
  mkdir -p "$token_dir" || return 1
  chmod 700 "$token_dir"
  printf '%s\n' "$token_value" > "$token_file" || return 1
  chmod 600 "$token_file"

  echo "✓ Codacy account token configured at $token_file"
  echo "  This token will be automatically available in all projects via direnv."
}

optional_integrations_menu() {
  local project="$1"
  while true; do
    local choice_count=1 gh_num="" codacy_num="" back_num=""

    # Check which services need configuration
    if ! (command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1); then
      gh_num="$choice_count"
      ((choice_count++))
    fi

    codacy_num="$choice_count"
    ((choice_count++))
    back_num="$choice_count"

    echo
    echo "Optional integrations and APIs:"
    [[ -n "$gh_num" ]] && echo "  $gh_num. Manage GitHub (gh) API access."
    echo "  $codacy_num. Manage Codacy API access."
    echo "  $back_num. Back to project setup."

    printf "Choose [1-%s]: " "$back_num"
    local choice
    if ! read -r -e choice; then
      echo
      echo "No optional integration selection received; project files were not changed."
      return 10
    fi

    if [[ -z "$choice" || "$choice" == "$back_num" ]]; then
      echo "No optional integration selection received; project files were not changed."
      return 10
    elif [[ -n "$gh_num" && "$choice" == "$gh_num" ]]; then
      configure_gh_auth "$project"
    elif [[ "$choice" == "$codacy_num" ]]; then
      configure_codacy_env "$project"
    else
      echo "Unknown choice: $choice" >&2
    fi
  done
}

empty_project_menu() {
  local project="$1" vars="$2"
  while true; do
    cat <<EOF

Project setup options:
  1. Bootstrap AGENTS.md plus CLAUDE.md/GEMINI.md symlinks.
  2. Bootstrap agent docs plus Copilot instructions.
  3. Open optional integrations and APIs.
  4. Show inferred project metadata.
  5. Exit.
EOF
    printf 'Choose [1-5]: '
    local choice
    if ! read -r -e choice; then
      echo
      echo "No interactive selection received; project files were not changed."
      return 0
    fi
    case "$choice" in
      1) cmd_init --project "$project" --vars "$vars" --yes; return $? ;;
      2) cmd_init --project "$project" --vars "$vars" --copilot --yes; return $? ;;
      3) if optional_integrations_menu "$project"; then :; else return 0; fi ;;
      4) show_project_vars "$vars" ;;
      5|"") echo "Project files were not changed."; return 0 ;;
      *) echo "Unknown choice: $choice" >&2 ;;
    esac
  done
}

existing_project_menu() {
  local project="$1" vars="$2"
  while true; do
    cat <<EOF

Project setup options:
  1. Verify agent docs.
  2. Repair/bootstrap AGENTS.md plus CLAUDE.md/GEMINI.md symlinks.
  3. Add or refresh Copilot instructions.
  4. Open optional integrations and APIs.
  5. Show project metadata.
  6. Exit.
EOF
    printf 'Choose [1-6]: '
    local choice
    if ! read -r -e choice; then
      echo
      echo "No interactive selection received; project files were not changed."
      return 0
    fi
    case "$choice" in
      1) cmd_verify --project "$project" || true ;;
      2) cmd_init --project "$project" --vars "$vars" --yes; return $? ;;
      3) cmd_init --project "$project" --vars "$vars" --copilot --yes; return $? ;;
      4) if optional_integrations_menu "$project"; then :; else return 0; fi ;;
      5) show_project_vars "$vars" ;;
      6|"") echo "Project files were not changed."; return 0 ;;
      *) echo "Unknown choice: $choice" >&2 ;;
    esac
  done
}

cmd_project_folder() {
  local project="$1" was_empty=0 vars
  project="$(resolve_project "$project")"
  project_is_empty "$project" && was_empty=1
  preflight_common
  preflight_project_templates
  vars="$(resolve_project_vars_file "$project")" || die "failed to resolve project metadata for: $project"

  echo "Inspecting project: $project"
  echo "Project metadata stored at: $vars"
  if [[ "$was_empty" -eq 1 ]]; then
    echo "Project folder is empty; agent-doc setup is available."
    empty_project_menu "$project" "$vars"
  else
    echo "Project folder has existing files; running a read-only verification first."
    cmd_verify --project "$project" || true
    existing_project_menu "$project" "$vars"
  fi
}

main() {
  if [[ $# -eq 0 ]]; then
    cmd_machine_setup
    return $?
  fi
  local sub="$1"; shift
  case "$sub" in
    verify) cmd_verify "$@" ;;
    init)   cmd_init "$@" ;;
    doctor) cmd_doctor "$@" ;;
    quality) cmd_quality "$@" ;;
    codacy-audit) cmd_codacy_audit "$@" ;;
    codacy-plan) cmd_codacy_plan "$@" ;;
    hooks) cmd_hooks "$@" ;;
    docker-build) cmd_docker_build "$@" ;;
    gstack-exec) cmd_gstack_exec "$@" ;;
    gstack-setup) cmd_gstack_setup "$@" ;;
    gstack-codex) cmd_gstack_codex "$@" ;;
    gstack-shell) cmd_gstack_shell "$@" ;;
    ship)   cmd_ship "$@" ;;
    repair-codacy-env) cmd_repair_codacy_env "$@" ;;
    help|-h|--help) usage ;;
    *)
      if [[ $# -eq 0 && -d "$sub" ]]; then
        cmd_project_folder "$sub"
      else
        usage
        die "unknown command or project path: $sub"
      fi
      ;;
  esac
}

main "$@"
